<table border="1" width="100%" id="reportTable">
    <tr>
        <th>客戶</th>
        <th>類型</th>
        <th>設備</th>
        <th>內容</th>
        <th>負責人</th>
        <th>日期</th>
    </tr>

    @for (int i = 0; i < Model.Count; i++)
    {
        var row = Model[i];

        <tr class="data-row"
            data-index="@(i + 2)"
            data-customer="@(row.Count > 0 ? row[0] : "")"
            data-type="@(row.Count > 1 ? row[1] : "")"
            data-equipment="@(row.Count > 2 ? row[2] : "")"
            data-content="@(row.Count > 3 ? row[3] : "")"
            data-owner="@(row.Count > 4 ? row[4] : "")">

            <td>@(row.Count > 0 ? row[0] : "")</td>
            <td>@(row.Count > 1 ? row[1] : "")</td>
            <td>@(row.Count > 2 ? row[2] : "")</td>
            <td>@(row.Count > 3 ? row[3] : "")</td>
            <td>@(row.Count > 4 ? row[4] : "")</td>
            <td>@(row.Count > 5 ? row[5] : "")</td>
        </tr>
    }
</table>