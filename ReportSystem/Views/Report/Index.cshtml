@model IList<IList<object>>

<h2>報告清單（點擊可編輯）</h2>

<table border="1" cellpadding="5">
    <tr>
        <th>客戶</th>
        <th>類型</th>
        <th>設備種類</th> <!-- ⭐ 新增 -->
        <th>內容</th>
        <th>負責人</th>
    </tr>

@foreach (var row in Model)
{
    <tr>
        <td>@(row.Count > 0 ? row[0] : "")</td>
        <td>@(row.Count > 1 ? row[1] : "")</td>
        <td>@(row.Count > 2 ? row[2] : "")</td> <!-- ⭐ -->
        <td>@(row.Count > 3 ? row[3] : "")</td>
        <td>@(row.Count > 4 ? row[4] : "")</td>
    </tr>
}

</table>

<br />
<a href="/Report/Create">新增報告</a>