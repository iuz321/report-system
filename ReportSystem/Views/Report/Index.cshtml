@model IList<IList<object>>

<h2>工作報告系統</h2>

<!-- 🔹 新增表單 -->
<form method="post" action="/Report/Add">

    客戶：
    <input type="text" name="Customer" />
    <br /><br />

    類型：
    <select name="Type">
        <option>打樣</option>
        <option>DEMO</option>
    </select>
    <br /><br />

    設備種類：
    <input type="text" name="Equipment" />
    <br /><br />

    內容：
    <textarea name="Content" style="width:300px;height:100px;"></textarea>
    <br /><br />

    負責人：
    <input type="text" name="Owner" />
    <br /><br />

    <button type="submit">送出</button>

</form>

<hr />

<h2>報告清單（點擊可編輯）</h2>

<table border="1" cellpadding="5">
    <tr>
        <th>客戶</th>
        <th>類型</th>
        <th>設備種類</th>
        <th>內容</th>
        <th>負責人</th>
    </tr>

@for (int i = 0; i < Model.Count; i++)
{
    var row = Model[i];

    <tr>
        <form method="post" action="/Report/Update">

            <input type="hidden" name="rowIndex" value="@(i + 2)" />

            <td><input name="Customer" value="@(row.Count>0?row[0]:"")" /></td>
            <td><input name="Type" value="@(row.Count>1?row[1]:"")" /></td>
            <td><input name="Equipment" value="@(row.Count>2?row[2]:"")" /></td>
            <td><input name="Content" value="@(row.Count>3?row[3]:"")" /></td>
            <td><input name="Owner" value="@(row.Count>4?row[4]:"")" /></td>

            <td><button type="submit">更新</button></td>

        </form>
    </tr>
}

</table>