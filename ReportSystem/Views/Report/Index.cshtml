@model IList<IList<object>>

@{
    // 🔥 排序（最新日期在上）
    var sorted = Model
        .Select(r => new
        {
            Row = r,
            Date = r.Count > 5 && DateTime.TryParse(r[5]?.ToString(), out var d)
                    ? d
                    : DateTime.MinValue
        })
        .OrderByDescending(x => x.Date)
        .ToList();
}

<div style="max-width:900px;margin:auto">

    <h2 style="text-align:center;background:#1f2d3d;color:white;padding:10px;border-radius:6px;">
        工作報告系統
    </h2>

    <!-- 表單 -->
    <form method="post" action="/Report/Save" style="margin-top:20px;">
        <input type="hidden" id="rowIndex" name="rowIndex" value="0" />

        <div>客戶：</div>
        <input id="Customer" name="Customer" style="width:100%;" />

        <div>類型：</div>
        <select id="Type" name="Type" style="width:100%;">
            <option>打樣</option>
            <option>DEMO</option>
        </select>

        <div>設備：</div>
        <input id="Equipment" name="Equipment" style="width:100%;" />

        <div>內容：</div>
        <textarea id="Content" name="Content" style="width:100%;height:100px;"></textarea>

        <div>負責人：</div>
        <input id="Owner" name="Owner" style="width:100%;" />

        <br />
        <button type="submit" style="background:#007bff;color:white;padding:10px;border:none;border-radius:4px;">
            送出 / 更新
        </button>
    </form>

    <hr />

    <!-- 表格樣式 -->
    <style>
        #reportTable {
            border-collapse: collapse;
            width: 100%;
            font-size: 14px;
        }

            #reportTable th {
                background-color: #2c3e50;
                color: white;
                padding: 10px;
                text-align: left;
            }

            #reportTable td {
                padding: 10px;
                border-bottom: 1px solid #ddd;
                vertical-align: top;
            }

            #reportTable tr:hover {
                background-color: #f5f5f5;
                cursor: pointer;
            }

            #reportTable tr:nth-child(even) {
                background-color: #fafafa;
            }

        .content-cell {
            white-space: pre-wrap;
            line-height: 1.5;
        }

        .right {
            text-align: right;
            white-space: nowrap;
        }
    </style>

    <!-- 表格 -->
    <table id="reportTable">
        <tr>
            <th>客戶</th>
            <th>類型</th>
            <th>設備</th>
            <th>內容</th>
            <th>負責人</th>
            <th>日期</th>
        </tr>

        @foreach (var item in sorted)
        {
            var row = item.Row;

            var customer = row.Count > 0 ? row[0]?.ToString() : "";
            var type = row.Count > 1 ? row[1]?.ToString() : "";
            var equipment = row.Count > 2 ? row[2]?.ToString() : "";
            var content = row.Count > 3 ? row[3]?.ToString() : "";
            var owner = row.Count > 4 ? row[4]?.ToString() : "";
            var date = row.Count > 5 ? row[5]?.ToString() : "";

            var realIndex = Model.IndexOf(row) + 2; // ⭐關鍵（對應 Google Sheet）

            <tr class="data-row"
                data-index="@realIndex"
                data-customer="@customer"
                data-type="@type"
                data-equipment="@equipment"
                data-content="@content"
                data-owner="@owner">

                <td>@customer</td>
                <td>@type</td>
                <td>@equipment</td>
                <td class="content-cell">@content</td>
                <td class="right">@owner</td>
                <td class="right">@date</td>
            </tr>
        }
    </table>

</div>

<!-- 點擊帶入編輯 -->
<script>
    document.querySelectorAll(".data-row").forEach(row => {
        row.addEventListener("click", function () {

            document.getElementById("rowIndex").value = this.dataset.index;

            document.getElementById("Customer").value = this.dataset.customer;
            document.getElementById("Type").value = this.dataset.type;
            document.getElementById("Equipment").value = this.dataset.equipment;
            document.getElementById("Content").value = this.dataset.content;
            document.getElementById("Owner").value = this.dataset.owner;

            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    });
</script>